{
  "name": "quransphere-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx concurrently \"next dev\" \"tsx watch backend/src/index.ts\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:backend": "tsc -p backend/tsconfig.json",
    "netlify:build": "npm run build && npm run build:backend",
    "deploy:manual": "npx cross-env NETLIFY_FORCE_DEPLOY=true npx netlify deploy --prod"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "netlify-cli": "^17.33.0",
    "cross-env": "^7.0.3"
  }
}
